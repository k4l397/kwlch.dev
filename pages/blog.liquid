---
permalink: /blog/
---

<!doctype html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; style-src 'self' 'unsafe-inline'" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" type="text/css" href="/css/main.css" />
    <link rel="icon" href="/favicon.ico" />
    <style>
      @font-face {
        font-family: "Quattrocento";
        src: url(/fonts/Quattrocento-Regular.ttf) format("truetype");
        font-weight: normal;
      }
      @font-face {
        font-family: "Fanwood Text";
        src: url(/fonts/FanwoodText-Regular.ttf) format("truetype");
        font-weight: normal;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      }
      h1,
      h2,
      h3 {
        font-family: "Quattrocento", serif;
      }
    </style>
    <title>Blog - kwlch.dev</title>
  </head>
  <body>
    <header id="site-header">
      <h1>Blog</h1>
    </header>
    <main class="blog-list">
      {% assign sorted_posts = collections.post | reverse %}
      {% for post in sorted_posts %}
      <a href="{{ post.url }}" class="blog-entry">
        <h2>{{ post.data.title }}</h2>
        <time datetime="{{ post.date | date: '%Y-%m-%d' }}">{{ post.date | date: '%d %B %Y' }}</time>
      </a>
      {% endfor %}
      {% if collections.post.size == 0 %}
      <p>No posts yet.</p>
      {% endif %}
    </main>
    <nav class="blog-nav">
      <a href="/">&larr;Home</a>
    </nav>
  </body>
</html>
