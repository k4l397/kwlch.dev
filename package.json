    "@parcel/core": "^2.16.4",
    "parcel": "^2.16.4",
    "prettier": "^3.3.3",
    "svgo": "^3.3.2"
  },
  "packageManager": "yarn@4.5.1",
  "volta": {
    "node": "23.2.0"
  }
}
